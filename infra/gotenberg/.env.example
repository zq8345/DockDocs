# Copy to .env and fill in. Do NOT commit the real .env.

# A subdomain you point (DNS A record) at this VPS's IP. Caddy gets a free TLS
# cert for it automatically on first start. Example: convert.dockdocs.app
GOTENBERG_DOMAIN=convert.dockdocs.app

# A long random shared secret. The Netlify function sends it as the
# X-DockDocs-Key header; Caddy rejects anything without it.
# Generate one with:  openssl rand -hex 32
GOTENBERG_SECRET=replace-with-openssl-rand-hex-32
